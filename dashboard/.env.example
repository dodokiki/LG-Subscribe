# Supabase – ใส่ค่าจาก Supabase Dashboard > Project Settings > API
# คัดลอกเป็น .env.local แล้วใส่ค่าจริง (ไม่ commit .env.local)

# URL โปรเจกต์ (เช่น https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# anon / public key (Publishable – ใช้ฝั่ง browser ได้)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role key (Secret – ใช้เฉพาะฝั่ง server ใน Server Actions)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
